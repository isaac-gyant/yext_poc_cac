        "sourceConfig": {
            "apiPullConfig": {
                "requestType": "GET",
                "url": "https://fabric.isaacnewton.dev/api/locations?pageSize=20",
                "dataFormat": "JSON",
                "authentication": {
                    "apiKey": {
                        "key": "x-api-key",
                        "value": "${{fabricHealthApiKey}}",
                        "setAsHeader": true
                    }
                },
                "paginationControl": {
                    "cursorPagination": {
                        "pageKey": "pageToken",
                        "cursor": "pagination.pageToken",
                        "cursorType": "TOKEN"
                    }
                }
            }
        },
        "baseSelector": {
            "type": "JSON",
            "header": "Entity Container",
            "path": "data"
        },
