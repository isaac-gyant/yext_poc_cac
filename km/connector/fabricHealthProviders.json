{
    "$id": "fabricHealthProviders",
    "$schema": "https://schema.yext.com/config/km/connector/v7",
    "displayName": "Fabric Health - Providers Connector",
    "source": {
        "sourceConfig": {
            "apiPullConfig": {
                "requestType": "GET",
                "url": "https://fabric.isaacnewton.dev/api/providers?pageSize=20",
                "dataFormat": "JSON",
                "authentication": {
                    "apiKey": {
                        "key": "x-api-key",
                        "value": "${{fabricHealthApiKey}}",
                        "setAsHeader": true
                    }
                },
                "paginationControl": {
                    "cursorPagination": {
                        "pageKey": "pageToken",
                        "cursor": "pagination.pageToken",
                        "cursorType": "TOKEN"
                    }
                }
            }
        },
        "baseSelector": {
            "type": "JSON",
            "header": "Entity Container",
            "path": "data"
        },
        "selectors": [
            {
                "type": "JSON",
                "header": "Entity ID",
                "path": "id"
            },
            {
                "type": "JSON",
                "header": "Name",
                "path": "displayName"
            },
            {
                "type": "JSON",
                "header": "NPI",
                "path": "npi"
            },
            {
                "type": "JSON",
                "header": "First Name",
                "path": "firstName"
            },
            {
                "type": "JSON",
                "header": "Last Name",
                "path": "lastName"
            },
            {
                "type": "JSON",
                "header": "Display Name",
                "path": "displayName"
            },
            {
                "type": "JSON",
                "header": "Gender",
                "path": "gender"
            },
            {
                "type": "JSON",
                "header": "Specialty",
                "path": "specialty"
            },
            {
                "type": "JSON",
                "header": "Subspecialty",
                "path": "subspecialty"
            },
            {
                "type": "JSON",
                "header": "Credentials",
                "path": "credentials"
            },
            {
                "type": "JSON",
                "header": "Accepting New Patients",
                "path": "acceptingNewPatients"
            },
            {
                "type": "JSON",
                "header": "Languages",
                "path": "languages"
            },
            {
                "type": "JSON",
                "header": "Bio",
                "path": "bio"
            },
            {
                "type": "JSON",
                "header": "Headshot URL",
                "path": "headshotUrl"
            },
            {
                "type": "JSON",
                "header": "Location IDs",
                "path": "locationIds"
            },
            {
                "type": "JSON",
                "header": "Phone",
                "path": "phone"
            },
            {
                "type": "JSON",
                "header": "Fax",
                "path": "fax"
            },
            {
                "type": "JSON",
                "header": "Email",
                "path": "email"
            },
            {
                "type": "JSON",
                "header": "Insurances Accepted",
                "path": "insurancesAccepted"
            },
            {
                "type": "JSON",
                "header": "Ratings Average",
                "path": "ratingsAverage"
            },
            {
                "type": "JSON",
                "header": "Ratings Count",
                "path": "ratingsCount"
            }
        ]
    },
    "destinationConfig": {
        "knowledgeGraphConfig": {
            "entityTypes": [
                "ce_healthcareProvider"
            ]
        }
    },
    "mappings": [
        {
            "clearValueIfBlank": false,
            "dropInvalidMapping": false,
            "field": "entityId",
            "header": "Entity ID",
            "subfieldPath": []
